{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt -- ${CLAUDE_TOOL_INPUT_FILE_PATH} 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Block if the tool is editing or writing to a sensitive file (matching glob .env, .env.example, Cargo.lock, package-lock.json, *.db, *.db-journal, *.db-wal, *.db-shm, .mcp.json, .claude/settings.json). Return a JSON response: {\"block\": true, \"reason\": \"...\"} if the file MATCHES any of those globs, otherwise {\"block\": false}."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git log:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(export:*)",
      "Bash(npx:*)"
    ],
    "deny": []
  }
}
